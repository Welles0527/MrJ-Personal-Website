    animation: biblePageTurn 620ms cubic-bezier(0.2, 0.72, 0.18, 1);
  }

  @keyframes biblePageTurn {
    0% { opacity: 0; transform: rotateY(0deg); }
    18% { opacity: 1; }
    100% { opacity: 0; transform: rotateY(-165deg); }
  }

  .bible-book-controls {
    position: relative;
    z-index: 4;
