  { title: '奇异恩典', theme: '恩典 / 悔改 / 见证', use: '适合福音信息、受洗见证、回应祷告。', scripture: '以弗所书 2:8-9', flow: '见证分享后使用，接 2 分钟安静祷告。' },
  { title: '圣哉三一歌', theme: '敬拜 / 圣洁 / 三一神', use: '适合主日开始、敬拜宣召、圣餐前后。', scripture: '以赛亚书 6:3', flow: '聚会开场使用，接认信或宣召经文。' },
  { title: '坚固保障', theme: '信靠 / 争战 / 安慰', use: '适合困难主题、小组祷告、信心回应。', scripture: '诗篇 46:1', flow: '代祷前使用，帮助小组把惧怕转成信靠。' },
  { title: '我知谁掌管明天', theme: '盼望 / 交托 / 等候', use: '适合每日灵修、病中探访、安慰场景。', scripture: '马太福音 6:34', flow: '结束前使用，接个人交托祷告。' }
];
---

<section class="bible-app" data-bible-app>
  <section class="bible-stage" aria-label="J-Space">
    <div class="bible-stage-copy">
      <p>J-Space</p>
    </div>

    <div class="bible-book-shell" data-feature-book aria-live="polite">
      <div class="bible-book-shadow" aria-hidden="true"></div>
      <div class="bible-book">
        <div class="bible-book-spine" aria-hidden="true"></div>
        <div class="bible-page bible-left-page">
          <p class="bible-page-kicker" data-feature-eyebrow>{featurePages[0].eyebrow}</p>
          <h2 data-feature-title>{featurePages[0].title}</h2>
          <blockquote>
            <span data-feature-quote>{featurePages[0].quote}</span>
            <cite data-feature-reference>{featurePages[0].reference}</cite>
          </blockquote>
          <p data-feature-summary>{featurePages[0].summary}</p>
          <a class="bible-page-action" data-feature-action href={featurePages[0].href}>{featurePages[0].action}</a>
        </div>
        <div class="bible-page bible-right-page">
          <div class="bible-page-art" data-feature-art data-art-id={featurePages[0].id} style={`--art-a:${featurePages[0].artA};--art-b:${featurePages[0].artB};--art-c:${featurePages[0].artC};`}>
            <img data-feature-image src={featurePages[0].image} alt="" loading="eager" decoding="async" />
            <span data-feature-status>{featurePages[0].status}</span>
          </div>
        </div>
        <div class="bible-turn-page" aria-hidden="true"></div>
      </div>
    </div>

    <div class="bible-book-controls" aria-label="翻页控制">
      <button type="button" data-feature-prev>上一页</button>
      <span data-feature-count>1 / {featurePages.length}</span>
      <button type="button" data-feature-next>下一页</button>
    </div>

    <nav class="bible-top-nav" aria-label="圣经网站板块导航">
      <a class="bible-home-link" href={`${basePath}topics/applications/inspiration-station`}>AI灵感站</a>
      <div class="bible-nav-scroll">
        {featurePages.map((page, index) => (
          <button type="button" data-feature-target={String(index)} class={index === 0 ? 'is-active' : ''}>{page.title}</button>
        ))}
      </div>
    </nav>
  </section>

  <section class="bible-reader-section" id="bible-reader" aria-labelledby="bible-reader-title">
    <div class="bible-reader-shell">
      <aside class="bible-reader-sidebar" data-bible-directory>
        <div class="bible-reader-brand">
          <div>
            <p>WEI READ</p>
            <h2 id="bible-reader-title">微读圣经</h2>
          </div>
          <button class="bible-directory-close" type="button" data-action="toggle-directory" aria-label="关闭目录">×</button>
        </div>

        <div class="bible-reader-tools">
          <label>
            <span>搜索经文或输入引用</span>
            <input data-bible-search type="search" placeholder="例如：创-1-2 / 创世-1-2 / 约3:16" autocomplete="off" />
          </label>
          <p data-bible-search-status>已导入创世记1、诗篇23、约翰福音3。</p>
        </div>

        <div class="bible-segmented" aria-label="旧约新约切换">
          <button type="button" data-testament="旧约" class="is-active">旧约</button>
          <button type="button" data-testament="新约">新约</button>
        </div>

        <div class="bible-view-toggle" aria-label="目录视图切换">
          <button type="button" data-view-mode="grid" class="is-active">宫格</button>
          <button type="button" data-view-mode="list">列表</button>
        </div>

        <div class="bible-book-list is-grid" data-book-list>
          {bookGroups[0].books.map(([slug, title, shortName]) => (
            <button type="button" data-book={slug}>
              <strong>{shortName}</strong>
              <span>{title}</span>
            </button>
          ))}
        </div>
      </aside>

      <main class="bible-reading-pane">
        <header class="bible-reading-header">
          <button class="bible-mobile-directory" type="button" data-action="toggle-directory">目录</button>
          <div>
            <p data-current-version>和合本 · 阅读器</p>
            <h2 data-current-title>创世记 1</h2>
          </div>
          <div class="bible-reading-actions">
            <button type="button" class="bible-theme-toggle" data-action="toggle-reading-theme" aria-pressed="false">深色阅读</button>
            <button type="button" data-action="cloud-login">登录同步</button>
            <div class="bible-speech-actions" aria-label="章节朗读控制">
              <button type="button" data-action="read-chapter" aria-pressed="false">朗读本章</button>
              <button class="bible-speech-icon" type="button" data-action="replay-chapter" aria-label="重新播放本章" title="重新播放本章" disabled>↻</button>
              <button class="bible-speech-icon" type="button" data-action="stop-reading" aria-label="停止朗读" title="停止朗读" disabled>■</button>
            </div>
            <span class="bible-login-account" data-login-account hidden></span>
            <span class="bible-reading-sync-status" data-reading-sync-status aria-live="polite"></span>
          </div>
        </header>

        <div class="bible-chapter-strip" data-chapter-list aria-label="章节选择"></div>
        <div class="bible-result-list" data-search-results hidden></div>
        <article class="bible-verses" data-verse-list></article>
      </main>

      <aside class="bible-notes-panel">
        <section>
          <h3>阅读进度</h3>
          <p data-last-read>正在载入阅读位置...</p>
          <div class="bible-reading-progress" data-reading-progress aria-live="polite"></div>
          <button class="bible-resume-bookmark" type="button" data-action="find-first-unread" title="定位到第一节未读经文">
            <span aria-hidden="true"></span>
            继续阅读
          </button>
        </section>
        <section id="bible-bookmarks">
          <button class="bible-panel-toggle" type="button" data-action="toggle-reader-bookmarks" aria-expanded="false">
            <span>经文收藏 <small data-bookmark-total>0 条</small></span>
          </button>
          <div class="bible-panel-export-row">
            <button type="button" data-action="export-bookmarks" title="导出全部经文收藏为 Excel">导出收藏 Excel</button>
          </div>
          <div class="bible-bookmark-search" data-reader-bookmark-search hidden>
            <label>
              <span>搜索收藏</span>
              <input data-bookmark-search type="search" placeholder="卷名 / 章节 / 经文" autocomplete="off" />
            </label>
            <p data-bookmark-search-status>可按卷名、章节、节号或经文搜索。</p>
          </div>
          <div data-bookmark-list class="bible-bookmark-list" hidden></div>
        </section>
        <section>
          <button class="bible-panel-toggle" type="button" data-action="toggle-reader-notes" aria-expanded="false">
            <span>我的笔记 <small data-note-total>0 条</small></span>
          </button>
          <div class="bible-panel-export-row">
            <button type="button" data-action="export-notes" title="导出全部笔记为 Excel">导出笔记 Excel</button>
          </div>
          <div class="bible-note-list" data-note-section-list hidden>
            <p>还没有笔记。</p>
          </div>
        </section>
      </aside>
    </div>
  </section>

  <section class="bible-feature-section" id="bible-videos" aria-labelledby="bible-videos-title">
    <div class="bible-section-shell">
      <p class="bible-section-kicker">WATCH</p>
      <h2 id="bible-videos-title">圣经视频</h2>
      <p class="bible-section-lede">以短课导读的方式整理观看路线；每张卡片都能回到对应经文章节继续阅读。</p>
      <div class="bible-card-grid">
        {videoModules.map((item) => (
          <article class="bible-board-card">
            <span>{item.meta}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <small>{item.guide}</small>
            <a href={item.href}>关联阅读</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bible-feature-section" id="bible-people" aria-labelledby="bible-people-title">
    <div class="bible-section-shell">
      <p class="bible-section-kicker">PEOPLE</p>
      <h2 id="bible-people-title">圣经人物</h2>
      <p class="bible-section-lede">以人物为入口，把故事、经文、主题和生命应用串起来。</p>
      <div class="bible-people-actions" aria-label="圣经人物工具">
        <a class="bible-section-link bible-character-map-link" href={characterMapHref}>打开圣经人物图谱</a>
        <a class="bible-section-link bible-person-ranking-link" href={lifespanRankingHref}>圣经寿命排名</a>
        <a class="bible-section-link bible-person-ranking-link" href={accessionRankingHref}>登基年龄排名</a>
      </div>
      <div class="bible-card-grid bible-people-grid">
        {peopleCards.map((person) => (
          <article class="bible-board-card">
            <span>{person.role}</span>
            <h3>{person.name}</h3>
            <p>{person.text}</p>
            <small>{person.refs}</small>
            <em>{person.question}</em>
            <a href={person.href}>进入线索</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bible-feature-section" id="bible-daily" aria-labelledby="bible-daily-title">
    <div class="bible-section-shell">
      <p class="bible-section-kicker">DAILY</p>
      <h2 id="bible-daily-title">每日读经</h2>
      <p class="bible-section-lede">一个 7 天读经计划，勾选进度会保存在本机浏览器。</p>
      <div class="bible-daily-summary" aria-live="polite">
        <strong data-daily-progress>0 / 7</strong>
        <span>今日可以从已收录章节开始，再按计划记录回应。</span>
      </div>
      <div class="bible-daily-plan">
        {dailyPlan.map((item, index) => (
          <label class="bible-daily-item">
            <input type="checkbox" data-daily-step={String(index)} />
            <span>{item.day}</span>
            <strong>{item.title}</strong>
            <em>{item.passage}</em>
            <small>{item.prompt}</small>
          </label>
        ))}
      </div>
    </div>
  </section>

  <section class="bible-feature-section" id="bible-groups" aria-labelledby="bible-groups-title">
    <div class="bible-section-shell">
      <p class="bible-section-kicker">GROUP</p>
      <h2 id="bible-groups-title">小组聚会</h2>
      <p class="bible-section-lede">提供一份可复制的查经流程，适合小组长快速带领一段经文讨论。</p>
      <div class="bible-group-layout">
        <article class="bible-board-card" data-group-guide>
          <span>60-75 MIN</span>
          <h3>小组查经模板</h3>
          <ol class="bible-plain-list">
            <li>开场祷告与近况分享。</li>
            <li>朗读本次经文两遍，第二遍请不同成员朗读。</li>
            <li>用观察、解释、应用三个层次讨论经文。</li>
            <li>记录本周行动和彼此代祷事项。</li>
          </ol>
        </article>
        <article class="bible-board-card">
          <span>QUESTIONS</span>
          <h3>讨论问题</h3>
          <ul class="bible-plain-list">
            {groupQuestions.map((question) => <li>{question}</li>)}
          </ul>
          <button type="button" data-action="copy-group-guide">复制提纲</button>
        </article>
      </div>
    </div>
  </section>

  <section class="bible-feature-section" id="bible-hymns" aria-labelledby="bible-hymns-title">
    <div class="bible-section-shell">
      <p class="bible-section-kicker">HYMN</p>
      <h2 id="bible-hymns-title">赞美诗歌</h2>
      <p class="bible-section-lede">按主题、经文和聚会流程整理诗歌索引；这里只提供使用建议，不展示完整歌词。</p>
      <a class="bible-worship-entry" href={worshipMusicHref}>
        <span class="bible-worship-entry-icon" aria-hidden="true">♫</span>
        <span class="bible-worship-entry-copy">
          <strong>进入敬拜音乐</strong>
          <small>收听精选华语敬拜与赞美诗</small>
        </span>
        <i aria-hidden="true">↗</i>
      </a>
      <div class="bible-card-grid">
        {hymnCards.map((hymn) => (
          <article class="bible-board-card">
            <span>{hymn.theme}</span>
            <h3>{hymn.title}</h3>
            <p>{hymn.use}</p>
            <small>{hymn.scripture}</small>
            <em>{hymn.flow}</em>
          </article>
        ))}
      </div>
    </div>
  </section>

  <dialog class="bible-login-modal" data-login-modal aria-labelledby="bible-login-title">
    <form method="dialog" class="bible-login-card" data-login-form>
      <button type="button" aria-label="关闭登录弹窗" data-action="close-login">×</button>
      <p>CLOUD SYNC</p>
      <h2 id="bible-login-title">登录后同步收藏和进度</h2>
      <label>
        <span>邮箱</span>
        <input name="email" type="email" autocomplete="email" required />
      </label>
      <label>
        <span>密码</span>
        <input name="password" type="password" autocomplete="current-password" required />
      </label>
      <label data-verify-field hidden>
        <span>邮箱验证码</span>
        <input name="verificationCode" type="text" autocomplete="one-time-code" />
      </label>
      <div class="bible-login-actions">
        <button type="submit" data-login-submit>登录</button>
        <button type="button" data-action="start-signup">注册并发送验证码</button>
      </div>
      <p data-login-status>未登录时会先保存到本机浏览器。</p>
    </form>
  </dialog>

  <dialog class="bible-note-modal" data-note-modal aria-labelledby="bible-note-title">
    <form method="dialog" class="bible-note-card" data-note-form>
      <button type="button" aria-label="关闭笔记弹窗" data-action="close-note">×</button>
      <p data-note-ref>经文笔记</p>
      <h2 id="bible-note-title">我的笔记</h2>
      <blockquote data-note-verse></blockquote>
      <label>
        <span>笔记内容</span>
        <textarea data-note-text name="noteText" rows="7" placeholder="写下你的观察、问题或回应。"></textarea>
      </label>
      <div class="bible-note-actions">
        <button type="submit">保存笔记</button>
        <button type="button" data-action="delete-note">删除笔记</button>
      </div>
      <p data-note-status>笔记会先保存在本机浏览器。</p>
    </form>
  </dialog>

  <dialog class="bible-note-modal" data-book-status-modal aria-labelledby="bible-book-status-title">
    <div class="bible-note-card">
      <button type="button" aria-label="关闭阅读状态弹窗" data-action="close-book-status">×</button>
      <p>READING STATUS</p>
      <h2 id="bible-book-status-title" data-book-status-title>设置阅读状态</h2>
      <p class="bible-book-status-help">选择后会保存在当前浏览器中，之后可再次双击修改。</p>
      <div class="bible-note-actions bible-book-status-actions">
        <button type="button" data-action="set-book-status" data-book-reading-status="reading" aria-pressed="false">在读</button>
        <button type="button" data-action="set-book-status" data-book-reading-status="read" aria-pressed="false">已读</button>
      </div>
    </div>
  </dialog>

  <p class="bible-toast" data-bible-toast hidden></p>
  <script is:inline type="application/json" id="bible-data" set:html={JSON.stringify(bibleData)}></script>

  <script>
    import { mountBibleReader } from '../scripts/bible-reader';

    const root = document.querySelector<HTMLElement>('[data-bible-app]');
    const dataElement = document.getElementById('bible-data');
    if (root && dataElement?.textContent) {
      mountBibleReader(root, JSON.parse(dataElement.textContent));
    }
  </script>
</section>

<style is:global>
  .main-content:has(.bible-app) {
    padding: 0;
  }

  .app-shell:has(.bible-app) {
    display: block;
  }

  .app-shell:has(.bible-app) > .sidebar,
  body:has(.bible-app) > .bottom-nav {
    display: none;
  }

  .main-content:has(.bible-app) .site-footer {
    display: none;
  }

  .bible-app {
    --gold: #d8b35f;
    --gold-soft: #f1d995;
    --night: #030303;
    --paper: #f8f0dc;
    --ink: #221a10;
    --muted: #786c5b;
    min-height: 100vh;
    background: #050505;
    color: #fff7e0;
    font-family: "Microsoft YaHei", "Noto Sans SC", system-ui, sans-serif;
  }

  .bible-app button,
  .bible-app input,
  .bible-app textarea {
    font: inherit;
  }

  .bible-stage {
    position: relative;
    overflow: hidden;
    padding: 1rem clamp(1rem, 2.8vw, 2.4rem) 1.25rem;
    background:
      radial-gradient(circle at 50% 42%, rgba(211, 180, 104, 0.22), transparent 18rem),
      radial-gradient(circle at 50% 88%, rgba(255, 244, 196, 0.1), transparent 22rem),
      linear-gradient(180deg, #000 0%, #050505 58%, #080604 100%);
  }

  .bible-stage::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(rgba(255, 255, 255, 0.08) 0.7px, transparent 0.7px);
    background-size: 18px 18px;
    opacity: 0.22;
    content: "";
  }

  .bible-top-nav {
    position: relative;
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 1rem;
    width: min(72vw, 860px);
    min-height: 3.6rem;
    margin: 1rem auto 0;
    border: 1px solid rgba(216, 179, 95, 0.2);
    border-radius: 999px;
    padding: 0.35rem 0.55rem;
    background: rgba(255, 246, 218, 0.04);
  }

  .bible-home-link {
    flex: 0 0 auto;
    color: var(--gold-soft);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-decoration: none;
  }

  .bible-nav-scroll {
    display: flex;
    flex: 1 1 auto;
    gap: 0.42rem;
    overflow-x: auto;
    padding-bottom: 0.2rem;
    scrollbar-width: none;
  }

  .bible-nav-scroll::-webkit-scrollbar {
    display: none;
  }

  .bible-nav-scroll button {
    flex: 0 0 auto;
    min-height: 2.2rem;
    border: 1px solid rgba(216, 179, 95, 0.18);
    border-radius: 999px;
    padding: 0.44rem 0.76rem;
    background: rgba(255, 246, 218, 0.04);
    color: rgba(255, 247, 224, 0.76);
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 800;
  }

  .bible-nav-scroll button.is-active {
    border-color: rgba(216, 179, 95, 0.7);
    background: rgba(216, 179, 95, 0.16);
    color: #fff5d4;
  }

  .bible-stage-copy {
    position: relative;
    z-index: 2;
    max-width: 31rem;
    padding-top: clamp(1.3rem, 2.4vw, 2.2rem);
  }

  .bible-stage-copy p,
  .bible-section-kicker,
  .bible-page-kicker,
  .bible-reader-brand p,
  .bible-login-card > p {
    margin: 0 0 0.55rem;
    color: var(--gold);
    font-family: ui-monospace, Consolas, monospace;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.16em;
  }

  .bible-book-shell {
    position: relative;
    z-index: 3;
    width: min(72vw, 860px);
    margin: clamp(0.9rem, 1.8vw, 1.4rem) auto 0;
    perspective: 1800px;
  }

  .bible-book-shadow {
    position: absolute;
    right: 7%;
    bottom: -2.4rem;
    left: 9%;
    height: 3rem;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(0, 0, 0, 0.78), transparent 70%);
    filter: blur(12px);
  }

  .bible-book {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: clamp(24rem, 40vw, 31rem);
    border-radius: 1.05rem;
    transform-style: preserve-3d;
    filter: drop-shadow(0 34px 50px rgba(0, 0, 0, 0.58));
  }

  .bible-book-spine {
    position: absolute;
    z-index: 4;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1.7rem;
    transform: translateX(-50%);
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.45), rgba(255, 255, 255, 0.16), rgba(0, 0, 0, 0.54));
    filter: blur(0.2px);
  }

  .bible-page {
    position: relative;
    overflow: hidden;
