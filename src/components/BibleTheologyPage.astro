  .bible-page-art[data-art-id="hymns"] .bible-art-notes {
    top: 28%;
    left: 28%;
    width: 1.7rem;
    height: 1.7rem;
    background: #3b216d;
    box-shadow:
      4.8rem 2.4rem 0 0.15rem #7c3aed,
      10rem 0.8rem 0 0.05rem #f97316,
      12.6rem 5rem 0 0.18rem #06b6d4;
  }

  .bible-page-art span {
    position: absolute;
    z-index: 2;
    right: 1.1rem;
    bottom: 1.1rem;
    border: 1px solid rgba(255, 241, 201, 0.3);
