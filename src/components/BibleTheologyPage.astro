    left: 13%;
    width: 75%;
    height: 10rem;
    border: 0;
    border-radius: 1.2rem;
    background: repeating-linear-gradient(0deg, transparent 0 1.12rem, rgba(66, 44, 105, 0.36) 1.18rem 1.3rem);
    transform: rotate(-5deg);
