    border-radius: 0.52rem;
    background: #fffaf0;
    color: #2d2112;
    cursor: pointer;
    text-align: left;
    touch-action: manipulation;
    transition: background-color 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }

  .bible-book-list.is-grid button {
    place-items: center;
    text-align: center;
  }

  .bible-book-list button strong {
    font-size: 1.18rem;
