---
const basePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

type NavItem = {
  label: string;
  icon: string;
  href?: string;
  action?: string;
  active?: boolean;
};

const navItems: NavItem[] = [
  { label: '首页', icon: '⌂', href: 'https://www.magicj.cn/officialwebsite/' },
  { label: '我的待办', icon: '▣', active: true },
  { label: '回收站', icon: '♙', action: 'open-trash' }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="按周规划、记录和完成 To-Do-List。" />
    <link rel="icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
    <link rel="shortcut icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
    <title>To-Do-List</title>
  </head>
  <body>
    <div class="todo-shell" data-todo-app>
      <div class="todo-backdrop" data-sidebar-backdrop hidden></div>

      <aside class="todo-sidebar" aria-label="待办功能导航" data-todo-sidebar>
        <div class="todo-brand">
          <span class="todo-brand-mark" aria-hidden="true">☕</span>
          <div>
            <strong>J-Space</strong>
            <span>WEEKLY FOCUS</span>
          </div>
          <button class="todo-sidebar-close" type="button" aria-label="关闭导航菜单" data-action="close-sidebar">×</button>
        </div>

        <nav class="todo-nav" aria-label="待办页面导航">
          {navItems.map((item) => item.href ? (
            <a class={item.active ? 'is-active' : ''} href={item.href}>
              <span class="todo-nav-icon" aria-hidden="true">{item.icon}</span>
              <span>{item.label}</span>
            </a>
          ) : item.action ? (
            <button class={item.active ? 'is-active' : ''} type="button" data-action={item.action}>
              <span class="todo-nav-icon" aria-hidden="true">{item.icon}</span>
              <span>{item.label}</span>
            </button>
          ) : (
            <span class={item.active ? 'is-active' : ''} aria-current={item.active ? 'page' : undefined}>
              <span class="todo-nav-icon" aria-hidden="true">{item.icon}</span>
              <span>{item.label}</span>
            </span>
          ))}
        </nav>

        <div class="todo-sidebar-lanes" data-sidebar-lanes></div>

        <div class="todo-sidebar-mail" aria-hidden="true">✉</div>
      </aside>

      <main class="todo-main">
        <header class="todo-header">
          <div class="todo-heading">
            <button class="todo-menu-button" type="button" aria-label="打开导航菜单" data-action="open-sidebar">☰</button>
            <div>
              <p class="todo-kicker" data-today-label>今天</p>
              <h1>To-Do-List <span class="todo-title-cup" aria-hidden="true">☕</span></h1>
            </div>
          </div>

          <div class="todo-header-actions" aria-label="页面操作">
            <span class="todo-account" data-auth-status>正在检查登录状态…</span>
            <button class="todo-account-button" type="button" data-action="open-login" data-login-open hidden>登录</button>
            <button class="todo-account-button" type="button" data-action="sign-out" data-sign-out hidden>退出登录</button>
            <span class="todo-utility" aria-label="搜索（视觉图标）" title="搜索">⌕</span>
            <span class="todo-utility" aria-label="设置（视觉图标）" title="设置">⚙</span>
            <span class="todo-utility" aria-label="提醒（视觉图标）" title="提醒">♧</span>
            <button class="todo-primary-button" type="button" data-action="open-create">
              <span aria-hidden="true">＋</span>
              新建待办
            </button>
          </div>
        </header>

        <section class="todo-filter-section" aria-label="待办分类筛选与数据工具">
          <div class="todo-filter-list" data-category-filters></div>
          <button class="todo-data-button" type="button" data-action="export-backup">
            <span aria-hidden="true">⇩</span>
            导出 Excel 备份
          </button>
        </section>

        <section class="todo-planner-card" aria-label="日期选择与当前周概览">
          <div class="todo-calendar-panel">
            <div class="todo-calendar-topline">
              <div class="todo-select-row">
                <label>
                  <span class="sr-only">年份</span>
                  <select data-control="year" aria-label="选择年份"></select>
                </label>
                <label>
                  <span class="sr-only">月份</span>
                  <select data-control="month" aria-label="选择月份"></select>
                </label>
                <label>
                  <span class="sr-only">周次</span>
                  <select data-control="week" aria-label="选择周次"></select>
                </label>
              </div>
            </div>
            <div class="todo-weekday-row" aria-hidden="true">
              <span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span><span>日</span>
            </div>
            <div class="todo-month-grid" data-month-calendar aria-label="月历"></div>
          </div>

          <div class="todo-week-overview-panel">
            <div class="todo-section-label">
              <span>当前周 · 7 天概览</span>
              <small data-week-range></small>
            </div>
            <div class="todo-week-overview-scroll">
              <div class="todo-week-overview" data-week-overview></div>
            </div>
            <div class="todo-overview-lanes" data-overview-lanes></div>
          </div>
        </section>

        <section class="todo-mobile-days" aria-label="切换当前日期" data-mobile-days></section>

        <section class="todo-board-section" aria-label="周一到周日任务区">
          <div class="todo-board-scroll">
            <div class="todo-weekly-board" data-weekly-board></div>
          </div>
        </section>

        <footer class="todo-stats" data-weekly-stats aria-live="polite" hidden></footer>
      </main>

      <dialog class="todo-modal" aria-labelledby="todo-form-title" data-todo-modal>
        <form class="todo-form" data-todo-form novalidate>
          <div class="todo-modal-header">
            <div>
              <p class="todo-kicker">安排一件事</p>
              <h2 id="todo-form-title" data-form-title>新增待办</h2>
            </div>
            <button class="todo-dialog-close" type="button" aria-label="关闭表单" data-action="close-form">×</button>
          </div>

          <label class="todo-field todo-field-wide">
            <span>待办标题 <b>*</b></span>
            <input name="title" type="text" autocomplete="off" maxlength="120" placeholder="例如：完成项目周报" required />
            <em data-title-error></em>
          </label>
          <div class="todo-form-grid">
            <label class="todo-field">
              <span>日期</span>
              <input name="date" type="date" />
            </label>
            <label class="todo-field">
              <span>分类 <b>*</b></span>
              <select name="category" required></select>
            </label>
            <label class="todo-field">
              <span>展示栏目</span>
              <select name="placement" required></select>
            </label>
          </div>
          <label class="todo-important-toggle">
            <input name="important" type="checkbox" />
            <span>标记为重要事项</span>
          </label>
          <label class="todo-field todo-field-wide">
            <span>备注</span>
            <textarea name="note" rows="3" maxlength="500" placeholder="可补充截止时间、上下文或下一步动作"></textarea>
          </label>
          <div class="todo-modal-actions">
            <button class="todo-secondary-button" type="button" data-action="close-form">取消</button>
            <button class="todo-primary-button" type="submit">保存待办</button>
          </div>
        </form>
      </dialog>

      <dialog class="todo-modal todo-delete-modal" aria-labelledby="todo-delete-title" data-delete-modal>
        <div class="todo-delete-content">
          <p class="todo-kicker">删除确认</p>
          <h2 id="todo-delete-title">删除这条待办？</h2>
          <p data-delete-message>删除后将进入回收站，可稍后恢复。</p>
          <div class="todo-modal-actions">
            <button class="todo-secondary-button" type="button" data-action="cancel-delete">取消</button>
            <button class="todo-danger-button" type="button" data-action="confirm-delete">确认删除</button>
          </div>
        </div>
      </dialog>

      <dialog class="todo-modal todo-trash-modal" aria-labelledby="todo-trash-title" data-trash-modal>
        <div class="todo-delete-content">
          <p class="todo-kicker">回收站</p>
          <h2 id="todo-trash-title">已删除待办</h2>
          <div class="todo-trash-list" data-trash-list></div>
          <div class="todo-modal-actions">
            <button class="todo-secondary-button" type="button" data-action="close-trash">关闭</button>
          </div>
        </div>
      </dialog>

      <dialog class="todo-modal todo-migration-modal" aria-labelledby="todo-migration-title" data-migration-modal>
        <div class="todo-delete-content">
          <p class="todo-kicker">数据迁移</p>
          <h2 id="todo-migration-title">迁移旧待办数据</h2>
          <p data-migration-status>正在检查 localhost 中保存的待办数据…</p>
          <div class="todo-modal-actions">
            <button class="todo-secondary-button" type="button" data-action="cancel-migration">取消</button>
            <button class="todo-primary-button" type="button" data-action="confirm-migration" disabled>合并导入</button>
          </div>
        </div>
      </dialog>

      <dialog class="todo-modal todo-login-modal" aria-labelledby="todo-login-title" data-login-modal>
        <form class="todo-form" data-login-form novalidate>
          <div class="todo-modal-header">
            <div>
              <p class="todo-kicker">云端待办</p>
              <h2 id="todo-login-title">登录我的待办</h2>
            </div>
          </div>
          <p class="todo-login-copy">使用同一账号登录后，可在 magicj.cn 下的页面共享登录状态；登录成功后默认 3 天内无需重复登录。</p>
          <label class="todo-field todo-field-wide">
            <span>邮箱</span>
            <input name="email" type="email" autocomplete="email" placeholder="输入常用邮箱" required />
          </label>
          <label class="todo-field todo-field-wide">
            <span>密码</span>
            <input name="password" type="password" autocomplete="current-password" minlength="8" placeholder="请输入私有密码" required />
          </label>
          <label class="todo-field todo-field-wide" data-verification-field hidden>
            <span>邮箱验证码</span>
            <input name="verificationCode" type="text" inputmode="numeric" autocomplete="one-time-code" maxlength="8" placeholder="输入邮箱收到的验证码" />
          </label>
          <p class="todo-login-message" data-login-message aria-live="polite"></p>
          <div class="todo-modal-actions">
            <button class="todo-secondary-button" type="button" data-action="sign-up">创建账号</button>
            <button class="todo-primary-button" type="submit">登录并同步</button>
          </div>
        </form>
      </dialog>

      <p class="todo-toast" role="status" aria-live="polite" data-toast hidden></p>
    </div>

    <script>
      import { mountTodoWorkspace } from '../scripts/todo-workspace';

      const todoRoot = document.querySelector<HTMLElement>('[data-todo-app]');
      if (todoRoot) mountTodoWorkspace(todoRoot);
    </script>

    <style is:global>
      :global(*) { box-sizing: border-box; }
      :global(html), :global(body) { min-width: 320px; margin: 0; background: #f2dfbf; }
      :global(body) {
        color: #261509;
        font-family: "Microsoft YaHei", "Noto Sans SC", system-ui, sans-serif;
      }
      :global(button), :global(input), :global(select), :global(textarea) { font: inherit; }
      :global(button) { cursor: pointer; }
      :global(a) { color: inherit; text-decoration: none; }

      .todo-shell {
        --espresso: #1d0d03;
        --leather: #311805;
        --leather-soft: #6f3a13;
        --coffee: #8a4716;
        --coffee-dark: #522708;
        --paper: #fff4e3;
        --paper-2: #f7e2bd;
        --paper-3: #fbe9cc;
        --line: rgba(111, 63, 23, 0.16);
        --muted: #7a5939;
        --shadow: 0 16px 38px rgba(74, 34, 6, 0.14);
        --category-all: #7a3f16;
        --category-work: #7a5ab8;
        --category-study: #d94f38;
        --category-life: #2f6fae;
        --category-health: #3d7b4f;
        --category-other: #d28a1e;
        --important-star: #e03131;
        --important-text: #3f2613;
        position: relative;
        display: grid;
        min-height: 100vh;
        grid-template-columns: 312px minmax(0, 1fr);
        overflow-x: hidden;
        background:
          radial-gradient(circle at 78% 4%, rgba(255,255,255,0.42), transparent 18rem),
          radial-gradient(circle at 40% 20%, rgba(174, 101, 28, 0.12), transparent 22rem),
          linear-gradient(105deg, #f6e4c6 0%, #f2dfbf 55%, #ecd2a7 100%);
      }

      .todo-shell::before {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image: radial-gradient(rgba(104, 55, 13, 0.12) 0.55px, transparent 0.55px);
        background-size: 14px 14px;
        opacity: 0.42;
        content: "";
      }

      .todo-sidebar,
      .todo-main,
      .todo-modal,
      .todo-toast {
        position: relative;
        z-index: 1;
      }

      .todo-sidebar {
        position: sticky;
        top: 0;
        display: flex;
        height: calc(100vh - 1rem);
        flex-direction: column;
        gap: 1.25rem;
        overflow-y: auto;
        margin: 0.5rem 0 0.5rem 0.5rem;
        padding: 1.45rem 0.95rem 1rem;
        border: 1px solid rgba(234, 174, 96, 0.2);
        border-radius: 0.95rem;
        background:
          radial-gradient(circle at 65% 82%, rgba(128, 73, 23, 0.35), transparent 10rem),
          repeating-linear-gradient(30deg, rgba(255,255,255,0.035) 0 1px, transparent 1px 11px),
          linear-gradient(145deg, #120701 0%, #2c1607 58%, #3b1e0b 100%);
        color: #f7deb4;
        box-shadow: 8px 0 22px rgba(58, 27, 4, 0.18);
      }

      .todo-brand {
        display: flex;
        align-items: center;
        gap: 0.74rem;
        padding: 0.55rem 0.5rem 1.15rem;
        border-bottom: 1px solid rgba(229, 166, 83, 0.18);
      }

      .todo-brand-mark {
        display: grid;
        width: 2.82rem;
        height: 2.82rem;
        place-items: center;
        border-radius: 50%;
        background: rgba(255, 236, 202, 0.08);
        color: #f7d89d;
        font-size: 1.55rem;
        box-shadow: inset 0 0 0 1px rgba(246, 206, 132, 0.22);
      }

      .todo-brand strong {
        display: block;
        color: #ffe5b8;
        font-family: inherit;
        font-size: 1.22rem;
        letter-spacing: 0.16em;
      }

      .todo-brand span:not(.todo-brand-mark),
      .todo-kicker {
        color: rgba(76, 45, 20, 0.78);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.08em;
      }

      .todo-brand div span {
        color: rgba(255, 223, 173, 0.72);
        font-size: 0.66rem;
        letter-spacing: 0.12em;
      }

      .todo-sidebar-close { display: none; }

      .todo-sidebar::-webkit-scrollbar { width: 0.36rem; }
      .todo-sidebar::-webkit-scrollbar-thumb {
        border-radius: 999px;
        background: rgba(255, 214, 144, 0.22);
      }

      .todo-nav {
        display: grid;
        gap: 0.42rem;
        padding-top: 0.3rem;
      }

      .todo-nav a,
      .todo-nav button,
      .todo-nav > span {
        display: flex;
        width: 100%;
        min-height: 2.95rem;
        align-items: center;
        gap: 0.76rem;
        border: 1px solid transparent;
        border-radius: 0.62rem;
        padding: 0.72rem 0.82rem;
        background: transparent;
        color: #f8dfb5;
        font-size: 0.95rem;
        font-weight: 800;
        text-align: left;
      }

      .todo-nav .is-active {
        border-color: rgba(255, 210, 134, 0.12);
        background: linear-gradient(90deg, rgba(135, 76, 25, 0.72), rgba(105, 56, 16, 0.28));
        color: #fff4d8;
        box-shadow: inset 4px 0 0 #b9782f;
      }

      .todo-nav-icon {
        display: grid;
        width: 1.15rem;
        place-items: center;
        color: #e2a042;
      }

      .todo-sidebar-lanes {
        display: grid;
        gap: 0.66rem;
        min-height: 0;
      }

      .todo-sidebar-lanes .todo-overview-lane {
        border-color: rgba(255, 214, 144, 0.16);
        padding: 0.58rem;
        background: rgba(96, 52, 18, 0.34);
      }

      .todo-sidebar-lanes .todo-overview-lane-title { color: #fff0cb; }
      .todo-sidebar-lanes .todo-overview-lane-count,
      .todo-sidebar-lanes .todo-overview-empty { color: #f2d8a9; }

      .todo-sidebar-lanes .todo-overview-list {
        max-height: 22.5rem;
      }

      .todo-sidebar-lanes .todo-overview-item {
        border-color: rgba(255, 214, 144, 0.14);
        background: rgba(255, 247, 232, 0.08);
      }

      .todo-sidebar-lanes .todo-overview-title { color: #fff7e2; }
      .todo-sidebar-lanes .todo-overview-note { color: #e4c79b; }

      .todo-sidebar-lanes .todo-overview-actions button,
      .todo-sidebar-lanes .todo-lane-add {
        border-color: rgba(255, 214, 144, 0.18);
        background: rgba(255, 232, 186, 0.1);
        color: #f5d59b;
      }

      .todo-sidebar-mail {
        margin-top: auto;
        align-self: center;
        display: grid;
        width: 3.2rem;
        height: 2.2rem;
        place-items: center;
        border: 1px solid rgba(255, 214, 144, 0.2);
        border-radius: 0.42rem;
        color: rgba(255, 224, 170, 0.58);
      }

      .todo-main {
        display: flex;
        width: min(100%, 1480px);
        min-height: 100vh;
        flex-direction: column;
        margin: 0 auto;
        padding: 1.35rem clamp(1.1rem, 2.2vw, 2.35rem) 1.05rem;
      }

      .todo-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: start;
        margin-bottom: 0.58rem;
      }

      .todo-heading {
        display: flex;
        align-items: flex-start;
        gap: 0.78rem;
      }

      .todo-heading h1 {
        display: flex;
        align-items: center;
        gap: 0.62rem;
        margin: 0.22rem 0 0;
        color: #1f1109;
        font-family: inherit;
        font-size: clamp(2rem, 3vw, 2.72rem);
        line-height: 1;
        letter-spacing: 0.03em;
      }

      .todo-title-cup {
        display: inline-grid;
        width: 2.25rem;
        height: 2.25rem;
        place-items: center;
        border-radius: 50%;
        background: rgba(255, 239, 214, 0.66);
        font-size: 1.38rem;
        box-shadow: 0 8px 16px rgba(93, 45, 7, 0.14);
      }

      .todo-menu-button { display: none; }

      .todo-header-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.58rem;
        padding-top: 0.38rem;
      }

      .todo-account {
        max-width: 16rem;
        overflow: hidden;
        color: #5f3c20;
        font-size: 0.82rem;
        font-weight: 800;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .todo-account-button,
      .todo-utility,
      .todo-data-button {
        border: 1px solid rgba(116, 69, 27, 0.14);
        background: rgba(255, 246, 231, 0.72);
        color: #5b3518;
        box-shadow: 0 8px 18px rgba(78, 37, 7, 0.06);
      }

      .todo-account-button {
        min-height: 2.28rem;
        border-radius: 999px;
        padding: 0.36rem 0.78rem;
        font-size: 0.76rem;
        font-weight: 900;
      }

      .todo-utility {
        display: grid;
        width: 2.65rem;
        height: 2.65rem;
        place-items: center;
        border-radius: 50%;
        font-size: 1.08rem;
      }

      .todo-primary-button,
      .todo-secondary-button,
      .todo-danger-button {
        min-height: 2.72rem;
        border-radius: 0.72rem;
        padding: 0.62rem 1rem;
        font-size: 0.88rem;
        font-weight: 900;
      }

      .todo-primary-button {
        display: inline-flex;
        align-items: center;
        gap: 0.38rem;
        border: 1px solid rgba(61, 25, 4, 0.42);
        background: linear-gradient(180deg, #9b541c, #5d2b09);
        color: #fff0ce;
        box-shadow: inset 0 1px 0 rgba(255, 224, 157, 0.24), 0 13px 22px rgba(74, 33, 4, 0.26);
      }

      .todo-secondary-button { border: 1px solid var(--line); background: #fff3dd; color: #65401d; }
      .todo-danger-button { border: 1px solid #8f3d1f; background: #9e4726; color: #fff0ce; }

      .todo-filter-section {
        display: flex;
        align-items: center;
        gap: 0.56rem;
        margin-bottom: 0.7rem;
      }

      .todo-filter-list {
        display: flex;
        flex: 0 1 auto;
        gap: 0.52rem;
        min-width: 0;
        overflow-x: auto;
        padding: 0.08rem 0.08rem 0.22rem;
        scrollbar-width: thin;
      }

      .todo-filter-list,
      .todo-week-overview-scroll,
      .todo-mobile-days {
        scrollbar-width: none;
      }

      .todo-filter-list::-webkit-scrollbar,
      .todo-week-overview-scroll::-webkit-scrollbar,
      .todo-mobile-days::-webkit-scrollbar {
        display: none;
      }

      .todo-filter,
      .todo-data-button {
        flex: 0 0 auto;
        min-height: 2.42rem;
        border-radius: 0.58rem;
