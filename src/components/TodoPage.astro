---
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="按周规划、记录和完成个人待办事项。" />
    <title>个人待办事项</title>
  </head>
  <body>
<div class="todo-shell" data-todo-app>
  <div class="todo-backdrop" data-sidebar-backdrop hidden></div>

  <aside class="todo-sidebar" aria-label="待办功能导航" data-todo-sidebar>
    <div class="todo-brand">
      <span class="todo-brand-mark" aria-hidden="true">✓</span>
      <div>
        <strong>待办事项</strong>
        <span>WEEKLY FOCUS</span>
      </div>
      <button class="todo-sidebar-close" type="button" aria-label="关闭导航菜单" data-action="close-sidebar">×</button>
    </div>

    <nav class="todo-nav" aria-label="待办页面导航">
      <span>首页</span>
      <span class="is-active" aria-current="page">我的待办</span>
      <span>日历视图</span>
      <span>四象限</span>
      <span>习惯追踪</span>
      <span>标签管理</span>
      <span>统计分析</span>
      <span>回收站</span>
    </nav>

    <div class="todo-sidebar-note">
      <strong>本周专注</strong>
      <span>把重要的事排进今天。</span>
    </div>
  </aside>

  <main class="todo-main">
    <header class="todo-header">
      <div class="todo-heading">
        <button class="todo-menu-button" type="button" aria-label="打开导航菜单" data-action="open-sidebar">☰</button>
        <div>
          <p class="todo-kicker" data-today-label>今天</p>
          <h1>个人待办事项</h1>
          <p class="todo-welcome">把一周安排清楚，也给生活留一点余地。</p>
        </div>
      </div>
      <div class="todo-header-actions">
        <span class="todo-account" data-auth-status>正在检查登录状态…</span>
        <button class="todo-account-button" type="button" data-action="sign-out" data-sign-out hidden>退出登录</button>
        <span class="todo-utility" aria-label="搜索（暂未启用）" title="搜索（暂未启用）">⌕</span>
        <span class="todo-utility" aria-label="通知（暂未启用）" title="通知（暂未启用）">◌</span>
        <button class="todo-primary-button" type="button" data-action="open-create">新增待办</button>
      </div>
    </header>

    <section class="todo-filter-section" aria-label="待办分类筛选">
      <div class="todo-filter-list" data-category-filters></div>
    </section>

    <section class="todo-data-tools" aria-label="待办数据工具">
      <span>数据工具</span>
      <button class="todo-data-button" type="button" data-action="start-migration">迁移旧 localhost 数据</button>
      <button class="todo-data-button" type="button" data-action="export-backup">导出备份</button>
    </section>

    <section class="todo-planner-card" aria-label="日期选择与当前周概览">
      <div class="todo-calendar-panel">
        <div class="todo-select-row">
          <label>
            <span class="sr-only">年份</span>
            <select data-control="year" aria-label="选择年份"></select>
          </label>
          <label>
            <span class="sr-only">月份</span>
            <select data-control="month" aria-label="选择月份"></select>
          </label>
          <label>
            <span class="sr-only">周次</span>
            <select data-control="week" aria-label="选择周次"></select>
          </label>
        </div>
        <div class="todo-weekday-row" aria-hidden="true">
          <span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span><span>日</span>
        </div>
        <div class="todo-month-grid" data-month-calendar aria-label="月历"></div>
      </div>

      <div class="todo-week-overview-panel">
        <div class="todo-section-label">
          <span>当前周 7 天概览</span>
          <small data-week-range></small>
        </div>
        <div class="todo-week-overview-scroll">
          <div class="todo-week-overview" data-week-overview></div>
        </div>
      </div>
    </section>

    <section class="todo-mobile-days" aria-label="切换当前日期" data-mobile-days></section>

    <section class="todo-board-section" aria-label="一周待办">
      <div class="todo-board-scroll">
        <div class="todo-weekly-board" data-weekly-board></div>
      </div>
    </section>

    <footer class="todo-stats" data-weekly-stats aria-live="polite"></footer>
  </main>

  <dialog class="todo-modal" aria-labelledby="todo-form-title" data-todo-modal>
    <form class="todo-form" data-todo-form novalidate>
      <div class="todo-modal-header">
        <div>
          <p class="todo-kicker">安排一件事</p>
          <h2 id="todo-form-title" data-form-title>新增待办</h2>
        </div>
        <button class="todo-dialog-close" type="button" aria-label="关闭表单" data-action="close-form">×</button>
      </div>

      <label class="todo-field todo-field-wide">
        <span>待办标题 <b>*</b></span>
        <input name="title" type="text" autocomplete="off" maxlength="120" placeholder="例如：完成项目周报" required />
        <em data-title-error></em>
      </label>
      <div class="todo-form-grid">
        <label class="todo-field">
          <span>日期 <b>*</b></span>
          <input name="date" type="date" required />
        </label>
        <label class="todo-field">
          <span>分类 <b>*</b></span>
          <select name="category" required></select>
        </label>
      </div>
      <label class="todo-important-toggle">
        <input name="important" type="checkbox" />
        <span>标记为重要事项</span>
      </label>
      <label class="todo-field todo-field-wide">
        <span>备注</span>
        <textarea name="note" rows="3" maxlength="500" placeholder="可补充截止时间、上下文或下一步动作"></textarea>
      </label>
      <div class="todo-modal-actions">
        <button class="todo-secondary-button" type="button" data-action="close-form">取消</button>
        <button class="todo-primary-button" type="submit">保存待办</button>
      </div>
    </form>
  </dialog>

  <dialog class="todo-modal todo-delete-modal" aria-labelledby="todo-delete-title" data-delete-modal>
    <div class="todo-delete-content">
      <p class="todo-kicker">删除确认</p>
      <h2 id="todo-delete-title">删除这条待办？</h2>
      <p data-delete-message>删除后无法恢复。</p>
      <div class="todo-modal-actions">
        <button class="todo-secondary-button" type="button" data-action="cancel-delete">取消</button>
        <button class="todo-danger-button" type="button" data-action="confirm-delete">确认删除</button>
      </div>
    </div>
  </dialog>

  <dialog class="todo-modal todo-migration-modal" aria-labelledby="todo-migration-title" data-migration-modal>
    <div class="todo-delete-content">
      <p class="todo-kicker">数据迁移</p>
      <h2 id="todo-migration-title">迁移旧待办数据</h2>
      <p data-migration-status>正在检查 localhost 中保存的待办数据…</p>
      <div class="todo-modal-actions">
        <button class="todo-secondary-button" type="button" data-action="cancel-migration">取消</button>
        <button class="todo-primary-button" type="button" data-action="confirm-migration" disabled>合并导入</button>
      </div>
    </div>
  </dialog>

  <dialog class="todo-modal todo-login-modal" aria-labelledby="todo-login-title" data-login-modal>
    <form class="todo-form" data-login-form novalidate>
      <div class="todo-modal-header">
        <div>
          <p class="todo-kicker">云端待办</p>
          <h2 id="todo-login-title">登录我的待办</h2>
        </div>
      </div>
      <p class="todo-login-copy">使用同一账号登录后，可在任意设备查看和管理自己的待办。</p>
      <label class="todo-field todo-field-wide">
        <span>邮箱</span>
        <input name="email" type="email" autocomplete="email" placeholder="输入常用邮箱" required />
      </label>
      <label class="todo-field todo-field-wide">
        <span>密码</span>
        <input name="password" type="password" autocomplete="current-password" minlength="8" placeholder="请输入私有密码" required />
      </label>
      <p class="todo-login-message" data-login-message aria-live="polite"></p>
      <div class="todo-modal-actions">
        <button class="todo-secondary-button" type="button" data-action="sign-up">创建账号</button>
        <button class="todo-primary-button" type="submit">登录并同步</button>
      </div>
    </form>
  </dialog>

  <p class="todo-toast" role="status" aria-live="polite" data-toast hidden></p>
</div>

<script>
  import { mountTodoWorkspace } from '../scripts/todo-workspace';

  const todoRoot = document.querySelector<HTMLElement>('[data-todo-app]');
  if (todoRoot) mountTodoWorkspace(todoRoot);
</script>

<style is:global>
  :global(*) { box-sizing: border-box; }
  :global(html), :global(body) { min-width: 320px; margin: 0; background: #f7f5f1; }
  :global(body) { color: #141413; font-family: "Microsoft YaHei", "Noto Sans SC", system-ui, sans-serif; }
  :global(button), :global(input), :global(select), :global(textarea) { font: inherit; }
  :global(button) { cursor: pointer; }

  .todo-shell {
    --clay: #d97757;
    --olive: #788c5d;
    --sky: #6a8caf;
    --oat: #e3dacc;
    --slate: #141413;
    --muted: #76746e;
    --line: #e6e1d8;
    --paper: #fffefd;
    --soft-blue: #eef4f8;
    --radius: 18px;
    display: grid;
    min-height: 100vh;
    grid-template-columns: 244px minmax(0, 1fr);
    background: #f7f5f1;
  }

  .todo-sidebar {
    position: sticky;
    top: 0;
    display: flex;
    height: 100vh;
    flex-direction: column;
    gap: 2rem;
    padding: 1.7rem 1rem 1.2rem;
    border-right: 1px solid var(--line);
    background: #fdfcf9;
  }

  .todo-brand { display: flex; align-items: center; gap: 0.72rem; padding: 0 0.55rem; }
  .todo-brand-mark { display: grid; width: 2.15rem; height: 2.15rem; place-items: center; border-radius: 0.72rem; background: var(--sky); color: #fff; font-weight: 900; box-shadow: 0 7px 16px rgba(106, 140, 175, 0.25); }
  .todo-brand div { display: grid; gap: 0.12rem; }
  .todo-brand strong { font-family: "Noto Serif SC", "Songti SC", serif; font-size: 1.06rem; letter-spacing: 0.03em; }
  .todo-brand div span, .todo-kicker { color: var(--muted); font-size: 0.66rem; font-weight: 700; letter-spacing: 0.11em; text-transform: uppercase; }
  .todo-sidebar-close { display: none; }

  .todo-nav { display: grid; gap: 0.38rem; }
  .todo-nav span { min-height: 2.85rem; padding: 0.8rem 0.9rem; border-radius: 0.75rem; color: #5e625f; font-size: 0.86rem; font-weight: 700; }
  .todo-nav .is-active { background: var(--soft-blue); color: #476f91; box-shadow: inset 0 0 0 1px rgba(106, 140, 175, 0.12); }
  .todo-sidebar-note { display: grid; gap: 0.3rem; margin-top: auto; padding: 1rem; border: 1px solid rgba(106, 140, 175, 0.16); border-radius: 1rem; background: linear-gradient(135deg, #f0f5f8, #fbfaf7); }
  .todo-sidebar-note strong { color: #476f91; font-size: 0.85rem; }
  .todo-sidebar-note span { color: var(--muted); font-size: 0.74rem; line-height: 1.5; }

  .todo-main { width: min(100%, 1560px); margin: 0 auto; padding: clamp(1.45rem, 3vw, 2.7rem); }
  .todo-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1.55rem; }
  .todo-heading { display: flex; align-items: flex-start; gap: 0.8rem; }
  .todo-heading h1, .todo-modal h2 { margin: 0.2rem 0 0; font-family: "Noto Serif SC", "Songti SC", serif; letter-spacing: -0.035em; }
  .todo-heading h1 { font-size: clamp(1.8rem, 3.1vw, 2.45rem); }
  .todo-welcome { margin: 0.4rem 0 0; color: var(--muted); font-size: 0.9rem; }
  .todo-menu-button { display: none; }
  .todo-header-actions { display: flex; align-items: center; gap: 0.72rem; }
  .todo-utility { display: grid; width: 2.5rem; height: 2.5rem; place-items: center; border: 1px solid var(--line); border-radius: 50%; color: #6e746f; font-size: 1.2rem; line-height: 1; }
  .todo-primary-button, .todo-secondary-button, .todo-danger-button { min-height: 2.55rem; border-radius: 0.68rem; padding: 0.62rem 1rem; font-size: 0.82rem; font-weight: 800; }
  .todo-primary-button { border: 1px solid #587ca0; background: var(--sky); color: #fff; box-shadow: 0 8px 18px rgba(106, 140, 175, 0.2); }
  .todo-primary-button:hover { background: #5a7e9f; }
  .todo-secondary-button { border: 1px solid var(--line); background: #fff; color: #555750; }
  .todo-danger-button { border: 1px solid #c65f4a; background: #cf6a55; color: #fff; }
  .todo-account { max-width: 10rem; overflow: hidden; color: var(--muted); font-size: 0.74rem; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
  .todo-account-button { min-height: 2.2rem; border: 1px solid var(--line); border-radius: 999px; padding: 0.4rem 0.7rem; background: #fffefd; color: #5a635f; font-size: 0.72rem; font-weight: 800; }
  .todo-login-copy, .todo-login-message { margin: 0 0 1rem; color: var(--muted); font-size: 0.82rem; line-height: 1.65; }
  .todo-login-message { min-height: 1.4rem; margin: 0; color: #b45d47; }

  .todo-filter-section { margin-bottom: 1.2rem; }
  .todo-filter-list { display: flex; gap: 0.55rem; overflow-x: auto; padding: 0.15rem 0 0.45rem; scrollbar-width: thin; }
  .todo-filter { flex: 0 0 auto; min-height: 2.45rem; border: 1px solid transparent; border-radius: 999px; padding: 0.52rem 0.95rem; background: #ebe8e1; color: #63645f; font-size: 0.8rem; font-weight: 800; }
  .todo-filter[data-category="all"] { background: #edf3f7; color: #456f91; }
  .todo-filter[data-category="work"] { background: #f5e7e1; color: #a85945; }
  .todo-filter[data-category="study"] { background: #e8f1e5; color: #597d52; }
  .todo-filter[data-category="life"] { background: #faefd9; color: #ae7628; }
  .todo-filter[data-category="health"] { background: #f6e5e3; color: #b9544d; }
  .todo-filter[data-category="other"] { background: #eee9f4; color: #75618b; }
  .todo-filter.is-active { border-color: currentColor; box-shadow: 0 5px 13px rgba(20, 20, 19, 0.08); transform: translateY(-1px); }

  .todo-data-tools { display: flex; align-items: center; gap: 0.52rem; margin: -0.15rem 0 1.15rem; color: var(--muted); font-size: 0.72rem; }
  .todo-data-tools > span { margin-right: 0.1rem; font-weight: 800; }
  .todo-data-button { min-height: 2rem; border: 1px solid var(--line); border-radius: 999px; padding: 0.38rem 0.7rem; background: #fffefd; color: #5a635f; font-size: 0.7rem; font-weight: 800; }
  .todo-data-button:hover { border-color: #a9c0d0; background: var(--soft-blue); color: #456f91; }

  .todo-planner-card { display: grid; grid-template-columns: minmax(300px, 0.68fr) minmax(0, 1.32fr); overflow: hidden; border: 1px solid var(--line); border-radius: var(--radius); background: var(--paper); box-shadow: 0 10px 30px rgba(41, 45, 40, 0.045); }
  .todo-calendar-panel { padding: 1.25rem 1.3rem 1.2rem; border-right: 1px solid var(--line); }
  .todo-select-row { display: grid; grid-template-columns: 1fr 0.84fr 1.05fr; gap: 0.48rem; margin-bottom: 1.2rem; }
  .todo-select-row select { width: 100%; min-height: 2.45rem; border: 1px solid var(--line); border-radius: 0.58rem; padding: 0 0.55rem; background: #fff; color: var(--slate); font-size: 0.78rem; font-weight: 700; }
  .todo-weekday-row, .todo-month-grid { display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; }
  .todo-weekday-row { margin-bottom: 0.3rem; color: #929087; font-size: 0.67rem; font-weight: 800; }
  .todo-month-day { position: relative; min-height: 2rem; border: 0; border-radius: 0.5rem; background: transparent; color: #454641; font-size: 0.74rem; }
  .todo-month-day:hover { background: #f1f5f7; color: #456f91; }
  .todo-month-day.is-outside { color: #c7c4bc; }
  .todo-month-day.is-in-week::before { position: absolute; z-index: 0; inset: 0.18rem 0.04rem; border-radius: 0.4rem; background: #edf3f7; content: ""; }
  .todo-month-day span { position: relative; z-index: 1; }
  .todo-month-day.is-selected span { display: inline-grid; width: 1.58rem; height: 1.58rem; place-items: center; border-radius: 50%; background: var(--sky); color: #fff; box-shadow: 0 4px 9px rgba(106, 140, 175, 0.28); }

  .todo-week-overview-panel { min-width: 0; padding: 1.35rem 1.45rem; }
  .todo-section-label { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
  .todo-section-label span { font-family: "Noto Serif SC", "Songti SC", serif; font-size: 1.1rem; font-weight: 800; }
  .todo-section-label small { color: var(--muted); font-size: 0.72rem; }
  .todo-week-overview-scroll { overflow-x: auto; padding-bottom: 0.22rem; }
  .todo-week-overview { display: grid; min-width: 670px; grid-template-columns: repeat(7, minmax(88px, 1fr)); gap: 0.58rem; }
  .todo-day-overview { display: grid; min-height: 7.7rem; align-content: start; gap: 0.55rem; border: 1px solid var(--line); border-radius: 0.85rem; padding: 0.9rem 0.72rem; background: #fff; color: #40413d; text-align: left; transition: border-color 160ms ease, background 160ms ease, transform 160ms ease; }
  .todo-day-overview:hover { border-color: #aec2d1; transform: translateY(-2px); }
  .todo-day-overview.is-selected { border-color: var(--sky); background: #f5f9fb; box-shadow: 0 8px 18px rgba(106, 140, 175, 0.12); }
  .todo-day-overview.is-weekend .todo-day-name { color: var(--clay); }
  .todo-day-name { font-size: 0.75rem; font-weight: 800; }
  .todo-day-date { font-family: "Noto Serif SC", "Songti SC", serif; font-size: 1.15rem; font-weight: 800; }
  .todo-day-count { color: var(--muted); font-size: 0.68rem; }
  .todo-day-dot { width: 0.38rem; height: 0.38rem; border-radius: 50%; background: var(--sky); }
  .todo-day-overview.is-weekend .todo-day-dot { background: var(--clay); }

  .todo-mobile-days { display: none; }
  .todo-board-section { margin-top: 1.25rem; }
  .todo-board-scroll { overflow-x: auto; padding-bottom: 0.45rem; }
  .todo-weekly-board { display: grid; min-width: 0; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: 0.65rem; }
  .todo-day-column { display: flex; min-height: 31rem; flex-direction: column; border: 1px solid var(--line); border-radius: 0.95rem; padding: 0.78rem; background: rgba(255, 254, 253, 0.82); }
  .todo-day-column.is-selected { border-color: #a3bfd3; background: #fbfdfe; }
  .todo-day-column.is-weekend .todo-column-name { color: var(--clay); }
  .todo-column-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.4rem; margin-bottom: 0.85rem; }
  .todo-column-name { margin: 0; font-family: "Noto Serif SC", "Songti SC", serif; font-size: 1rem; }
  .todo-column-date { margin: 0.22rem 0 0; color: var(--muted); font-size: 0.72rem; }
  .todo-add-icon { display: grid; width: 1.95rem; height: 1.95rem; place-items: center; border: 1px solid transparent; border-radius: 50%; background: #f2f4f2; color: #52615c; font-size: 1.2rem; line-height: 1; }
  .todo-add-icon:hover { border-color: #a9c0d0; background: #edf3f7; color: #456f91; }
  .todo-list { display: grid; gap: 0.55rem; margin: 0; padding: 0; list-style: none; }
  .todo-empty-day { margin: 1rem 0 0; color: #aaa69e; font-size: 0.73rem; line-height: 1.6; text-align: center; }
  .todo-item { display: grid; grid-template-columns: auto minmax(0, 1fr); gap: 0.45rem; align-items: start; border: 1px solid #ebe7df; border-radius: 0.72rem; padding: 0.68rem; background: #fff; box-shadow: 0 4px 10px rgba(46, 48, 43, 0.025); }
  .todo-checkbox { width: 1.05rem; height: 1.05rem; grid-row: span 2; margin: 0.1rem 0 0; accent-color: var(--sky); }
  .todo-item-main { min-width: 0; }
  .todo-item-title { margin: 0; color: #32332f; font-size: 0.78rem; font-weight: 800; line-height: 1.45; overflow-wrap: anywhere; }
  .todo-item.is-completed .todo-item-title { color: #9b9993; text-decoration: line-through; }
  .todo-item-note { margin: 0.32rem 0 0; color: var(--muted); font-size: 0.67rem; line-height: 1.45; overflow-wrap: anywhere; }
  .todo-tags { display: flex; flex-wrap: wrap; gap: 0.28rem; margin-top: 0.52rem; }
  .todo-tag { border-radius: 999px; padding: 0.16rem 0.35rem; font-size: 0.62rem; font-weight: 800; }
  .todo-tag.work { background: #f5e7e1; color: #a85945; }
  .todo-tag.study { background: #e8f1e5; color: #597d52; }
  .todo-tag.life { background: #faefd9; color: #ae7628; }
  .todo-tag.health { background: #f6e5e3; color: #b9544d; }
