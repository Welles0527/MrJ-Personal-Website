---
import { categoryFilterPath, categoryPath, themePath, type Theme } from '../data/site';

interface Props {
  theme: Theme;
  index: number;
}

const { theme, index } = Astro.props;
const featuredCategories = theme.categories.slice(0, 4);
---

<article class:list={['topic-card', `tone-${theme.color}`]}>
  <div class="topic-card-copy">
    <div class="topic-heading">
      <span class="topic-index">{String(index + 1).padStart(2, '0')}</span>
      <h2><a href={themePath(theme)}>{theme.title}</a></h2>
    </div>
    <p>{theme.description}</p>
    <ul class="category-links" aria-label={`${theme.title}分类`}>
      {featuredCategories.map((category) => (
        <li>
          <a href={categoryPath(theme, category)}>{category.title}</a>
          {category.filters?.length && (
            <ul class="term-filter-links" aria-label={`${category.title}分类`}>
              {category.filters.map((filter) => <li><a href={categoryFilterPath(theme, category, filter)}>{filter.title}</a></li>)}
            </ul>
          )}
        </li>
      ))}
    </ul>
    <a class="topic-action" href={themePath(theme)}>进入板块</a>
  </div>
  <img class="topic-illustration" src={theme.image} alt={`${theme.title}线稿插画`} loading="lazy" />
</article>
