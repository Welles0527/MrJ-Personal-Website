---
import { themes } from '../data/site';

interface Props {
  activeTheme?: string;
}

const { activeTheme } = Astro.props;
---

<nav class="bottom-nav" aria-label="移动端主题导航">
  {themes.map((theme) => (
    <a class:list={{ active: theme.slug === activeTheme }} href={`/topics/${theme.slug}`}>{theme.shortLabel}</a>
  ))}
</nav>
