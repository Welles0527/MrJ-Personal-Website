---
import Sidebar from '../components/Sidebar.astro';
import BottomNavigation from '../components/BottomNavigation.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  activeTheme?: string;
}

const { title = '学问笔记', activeTheme } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="J先生AI学习网站：AI知识、实用工具、项目搭建与个人学习记录。" />
    <title>{title}</title>
  </head>
  <body>
    <div class="app-shell">
      <Sidebar activeTheme={activeTheme} />
      <main class="main-content">
        <slot />
        <footer class="site-footer">
          <span>© {new Date().getFullYear()} 学问笔记</span>
          <span>个人投资内容仅为个人记录，不构成投资建议。</span>
        </footer>
      </main>
    </div>
    <BottomNavigation activeTheme={activeTheme} />
  </body>
</html>
