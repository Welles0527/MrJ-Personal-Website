---
import Sidebar from '../components/Sidebar.astro';
import BottomNavigation from '../components/BottomNavigation.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  activeTheme?: string;
  bare?: boolean;
}

const { title = '学问笔记', activeTheme, bare = false } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="J先生AI学习网站：AI知识、实用工具、项目搭建与个人学习记录。" />
    <meta name="theme-color" content="#1e160b" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
    <link rel="shortcut icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
    <link rel="manifest" href={`${basePath}manifest.webmanifest`} />
    <link rel="apple-touch-icon" href={`${basePath}icons/icon-192.png`} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-update-notice" role="status" aria-live="polite" data-site-update-notice hidden>
      <span>网站已有新版本。</span>
      <button type="button" data-site-update-refresh>刷新并更新</button>
    </div>
    <div class:list={['app-shell', { 'app-shell--bare': bare }]}>
      {!bare && <Sidebar activeTheme={activeTheme} />}
      <main class="main-content">
        <slot />
        {!bare && (
          <footer class="site-footer">
            <span>© {new Date().getFullYear()} 学问笔记</span>
            <span>个人投资内容仅为个人记录，不构成投资建议。</span>
          </footer>
        )}
      </main>
    </div>
    <BottomNavigation activeTheme={activeTheme} />
    <script>
      import { mountSiteAuthStatus } from '../scripts/site-auth-widget';

      mountSiteAuthStatus();
    </script>
    <script>
      if (import.meta.env.PROD && 'serviceWorker' in navigator) {
        const pwaBasePath = import.meta.env.BASE_URL.endsWith('/')
          ? import.meta.env.BASE_URL
          : `${import.meta.env.BASE_URL}/`;
        const updateNotice = document.querySelector<HTMLElement>('[data-site-update-notice]');
        const updateButton = document.querySelector<HTMLButtonElement>('[data-site-update-refresh]');
        const hadController = Boolean(navigator.serviceWorker.controller);
        let registration: ServiceWorkerRegistration | null = null;

        const showUpdateNotice = () => {
          if (updateNotice) updateNotice.hidden = false;
        };

        navigator.serviceWorker.addEventListener('controllerchange', () => {
          if (hadController) showUpdateNotice();
        });

        updateButton?.addEventListener('click', () => {
          registration?.waiting?.postMessage({ type: 'SKIP_WAITING' });
          window.location.reload();
        });

        navigator.serviceWorker.register(`${pwaBasePath}sw.js`, {
          scope: pwaBasePath,
          updateViaCache: 'none'
        }).then((nextRegistration) => {
          registration = nextRegistration;
          if (nextRegistration.waiting && navigator.serviceWorker.controller) showUpdateNotice();

          nextRegistration.addEventListener('updatefound', () => {
            const worker = nextRegistration.installing;
            worker?.addEventListener('statechange', () => {
              if (worker.state === 'installed' && navigator.serviceWorker.controller) showUpdateNotice();
            });
          });

          return nextRegistration.update();
        }).catch((error) => {
          console.warn('[site-update] Service Worker update check failed.', error);
        });
      }
    </script>
    <style>
      .site-update-notice {
        position: fixed;
        z-index: 1000;
        right: 1rem;
        bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        max-width: calc(100vw - 2rem);
        border: 1px solid rgba(255, 224, 166, 0.25);
        border-radius: 0.75rem;
        padding: 0.7rem 0.85rem;
        background: #2d1607;
        color: #fff1d2;
        box-shadow: 0 12px 30px rgba(35, 15, 2, 0.32);
        font-size: 0.86rem;
      }

      .site-update-notice[hidden] { display: none; }

      .site-update-notice button {
        flex: 0 0 auto;
        border: 0;
        border-radius: 999px;
        padding: 0.45rem 0.75rem;
        background: #f5c77d;
        color: #341805;
        font: inherit;
        font-weight: 800;
        cursor: pointer;
      }
    </style>
  </body>
</html>
